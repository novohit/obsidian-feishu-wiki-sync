{
  "name": "obsidian-feishu-wiki-sync",
  "version": "0.2.0",
  "description": "将 Obsidian 笔记同步到飞书知识库",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "check": "tsc -noEmit -skipLibCheck",
    "build": "npm run check && node esbuild.config.mjs production",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "obsidian",
    "feishu",
    "wiki",
    "sync"
  ],
  "author": "wwz",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "7.x",
    "@typescript-eslint/parser": "7.x",
    "builtin-modules": "3.3.0",
    "esbuild": "^0.25.12",
    "obsidian": "latest",
    "tslib": "2.6.0",
    "typescript": "5.4.x"
  }
}
